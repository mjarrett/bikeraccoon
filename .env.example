# BikeRaccoon environment variables
# Copy to /srv/br-tracker/.env and fill in values

# ── Environment ───────────────────────────────────────────────────────────────
BR_ENV=DEV  # DEV, STG, or PROD

# ── Tracker ───────────────────────────────────────────────────────────────────
BR_SYSTEMS_FILE=/srv/br-tracker/systems.json
BR_DATA_PATH=/srv/br-tracker/tracker-data
BR_LOG_PATH=/srv/br-tracker/logs

# ── API ───────────────────────────────────────────────────────────────────────
BR_DB_PATH=/srv/br-tracker/api.db
BR_ADMIN_KEY=changeme

# ── Email alerts (optional) ───────────────────────────────────────────────────
BR_SMTP_HOST=smtp.example.com
BR_SMTP_PORT=587
BR_SMTP_FROM=alerts@example.com
BR_SMTP_TO=you@example.com
BR_SMTP_USERNAME=alerts@example.com
BR_SMTP_PASSWORD=
